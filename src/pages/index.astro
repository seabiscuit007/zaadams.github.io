const photos = [
	{ src: "/Portfolio00007.jpg", alt: "Portfolio photo 7" },
	{ src: "/Portfolio00015.jpg", alt: "Portfolio photo 15" },
	{ src: "/Portfolio00003.jpg", alt: "Portfolio photo 3" },
	{ src: "/Portfolio00021.jpg", alt: "Portfolio photo 21" },
	{ src: "/Portfolio00010.jpg", alt: "Portfolio photo 10" },
	{ src: "/Portfolio00025.jpg", alt: "Portfolio photo 25" },
	{ src: "/Portfolio00001.jpg", alt: "Portfolio photo 1" },
	{ src: "/Portfolio00018.jpg", alt: "Portfolio photo 18" },
	{ src: "/Portfolio00013.jpg", alt: "Portfolio photo 13" },
	{ src: "/Portfolio00006.jpg", alt: "Portfolio photo 6" },
	{ src: "/Portfolio00028.jpg", alt: "Portfolio photo 28" },
	{ src: "/Portfolio00020.jpg", alt: "Portfolio photo 20" },
	{ src: "/Portfolio00004.jpg", alt: "Portfolio photo 4" },
	{ src: "/Portfolio00016.jpg", alt: "Portfolio photo 16" },
	{ src: "/Portfolio00009.jpg", alt: "Portfolio photo 9" },
	{ src: "/Portfolio00023.jpg", alt: "Portfolio photo 23" },
	{ src: "/Portfolio00011.jpg", alt: "Portfolio photo 11" },
	{ src: "/Portfolio00026.jpg", alt: "Portfolio photo 26" },
	{ src: "/Portfolio00002.jpg", alt: "Portfolio photo 2" },
	{ src: "/Portfolio00019.jpg", alt: "Portfolio photo 19" },
	{ src: "/Portfolio00014.jpg", alt: "Portfolio photo 14" },
	{ src: "/Portfolio00008.jpg", alt: "Portfolio photo 8" },
	{ src: "/Portfolio00027.jpg", alt: "Portfolio photo 27" },
	{ src: "/Portfolio00017.jpg", alt: "Portfolio photo 17" },
	{ src: "/Portfolio00005.jpg", alt: "Portfolio photo 5" },
	{ src: "/Portfolio00022.jpg", alt: "Portfolio photo 22" },
	{ src: "/Portfolio00024.jpg", alt: "Portfolio photo 24" },
	{ src: "/Portfolio00012.jpg", alt: "Portfolio photo 12" },
];

const videos = [
	{ thumbnail: "/fpv-thumb-1.jpg", url: "https://youtu.be/4AeC1PfFEOk" },
	{ thumbnail: "/fpv-thumb-2.jpg", url: "https://youtu.be/zEch6-N2R1w" },
	{ thumbnail: "/fpv-thumb-3.jpg", url: "https://youtu.be/HjsRMvdApB8" },
	{ thumbnail: "/fpv-thumb-4.jpg", url: "https://youtu.be/4b4mly0tHQU" },
	{ thumbnail: "/fpv-thumb-5.jpg", url: "https://youtu.be/9rjauuSO_ZQ" },
	{ thumbnail: "/fpv-thumb-6.jpg", url: "https://youtu.be/aAH-jcWaoG4" },
	{ thumbnail: "/fpv-thumb-7.jpg", url: "https://youtu.be/GlUAXS6TA7o" },
	{ thumbnail: "/fpv-thumb-8.jpg", url: "https://youtu.be/T-c3c-70NQ4" },

];
const aerialVideos = [
	{ url: "https://youtu.be/-92Noiuu9zs" },
	{ url: "https://youtu.be/K2yuxxNwCCE" },
	{ url: "https://youtu.be/49HODTFYPHc" },
	{ url: "https://youtu.be/j5dB43Tkm2E" },
	{ url: "https://youtu.be/TcAvqA5leao" },
	{ url: "https://youtu.be/iqVuZ8xCyU8" },
	{ url: "https://youtu.be/SFQUqDZyAr8" },
	{ url: "https://youtu.be/GQXWS-F4qwU" },
];
---

<Layout>
	<main>

		<section class="hero">
			<div class="hero-video">
				<iframe
					src="https://www.youtube.com/embed/XsXBpHuWYYY?autoplay=1&mute=1&loop=1&playlist=XsXBpHuWYYY&controls=0&showinfo=0&rel=0&modestbranding=1"
					frameborder="0"
					allow="autoplay; fullscreen"
				></iframe>
				<div class="hero-overlay"></div>
			</div>
			<div class="hero-content">
	<h1>Zach Adams</h1>
	<p class="tagline">Aerial & FPV Videography · Provo, UT</p>
	<div class="hero-btns">
		<a href="#fpv" class="btn">View Work</a>
		<a href="#contact" class="btn">Get In Touch</a>
	</div>
</div>
		</section>

		<section class="fpv" id="fpv">
			<h2>FPV</h2>
			<div class="video-grid">
				{videos.map(video => (
					<div class="video-card" data-url={video.url}>
						<div class="video-thumb">
							<img src={`https://img.youtube.com/vi/${video.url.includes('youtu.be') ? video.url.split('youtu.be/')[1] : video.url.split('v=')[1]}/maxresdefault.jpg`} alt="FPV clip" />
							<div class="play-btn">&#9654;</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="aerial-video" id="aerial-video">
	<h2>Aerial</h2>
	<div class="video-grid">
		{aerialVideos.map(video => (
			<div class="video-card" data-url={video.url}>
				<div class="video-thumb">
					<img src={`https://img.youtube.com/vi/${video.url.split('youtu.be/')[1]}/maxresdefault.jpg`} alt="Aerial clip" />
					<div class="play-btn">&#9654;</div>
				</div>
			</div>
		))}
	</div>
</section>

		<section class="portfolio" id="portfolio">
			<h2>Photography & Aerial</h2>
			<div class="photo-grid">
				{photos.map(photo => (
					<div class="photo-card">
						<img src={photo.src} alt={photo.alt} />
					</div>
				))}
			</div>
		</section>

		<section class="contact" id="contact">
	<h2>Get In Touch</h2>
	<p>Available for commercial and creative projects.</p>
	<a href="mailto:zach@zaadams.com" class="btn">zach@zaadams.com</a>
</section>

		<div class="lightbox" id="lightbox">
			<div class="lightbox-content">
				<img id="lightbox-img" src="" alt="" />
				<iframe id="lightbox-video" src="" allowfullscreen></iframe>
			</div>
		</div>

	</main>
</Layout>

<style>
	main {
		width: 100%;
	}

	.hero {
		position: relative;
		height: 100vh;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.hero-video {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 177.78vh;
		height: 100vh;
		min-width: 100%;
		min-height: 56.25vw;
		pointer-events: none;
	}

	.hero-video iframe {
		width: 100%;
		height: 100%;
		border: none;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0,0,0,0.45);
	}

	.hero-content {
		position: relative;
		z-index: 1;
		padding: 0 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	h1 {
		font-size: 4rem;
		font-weight: 700;
		margin: 0;
		letter-spacing: -1px;
	}

	.tagline {
		font-size: 1.2rem;
		color: #ccc;
		margin-top: 0.75rem;
	}

	.btn {
		margin-top: 2rem;
		padding: 0.75rem 2rem;
		border: 1px solid #ffffff;
		color: #ffffff;
		text-decoration: none;
		font-size: 0.95rem;
		letter-spacing: 1px;
		text-transform: uppercase;
		transition: background 0.2s, color 0.2s;
	}

	.btn:hover {
		background: #ffffff;
		color: #0a0a0a;
	}

	.fpv {
		max-width: 1200px;
		margin: 0 auto;
		padding: 6rem 2rem;
		position: relative;
		z-index: 1;
		background: #0a0a0a;
	}

	.aerial-video {
	max-width: 1200px;
	margin: 0 auto;
	padding: 6rem 2rem;
	position: relative;
	z-index: 1;
	background: #0a0a0a;
	border-top: 1px solid #222;
}

	.portfolio {
		max-width: 1200px;
		margin: 0 auto;
		padding: 6rem 2rem;
		position: relative;
		z-index: 1;
		background: #0a0a0a;
		border-top: 1px solid #222;
	}

	h2 {
		font-size: 1rem;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: #888;
		margin-bottom: 3rem;
	}

	.video-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 1.5rem;
	}

	.video-card {
		cursor: pointer;
	}

	.video-thumb {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
	}

	.video-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.video-card:hover img {
		transform: scale(1.05);
	}

	.play-btn {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 56px;
		height: 56px;
		background: rgba(255,255,255,0.15);
		backdrop-filter: blur(4px);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.2rem;
		color: white;
		transition: background 0.2s;
	}

	.video-card:hover .play-btn {
		background: rgba(255,255,255,0.3);
	}

	.photo-grid {
		columns: 3;
		column-gap: 1rem;
	}

	.photo-card {
		break-inside: avoid;
		margin-bottom: 1rem;
		cursor: pointer;
		overflow: hidden;
	}

	.photo-card img {
		width: 100%;
		display: block;
		transition: transform 0.4s ease;
	}

	.photo-card:hover img {
		transform: scale(1.03);
	}

	.contact {
	text-align: center;
	padding: 6rem 2rem;
	border-top: 1px solid #222;
	position: relative;
	z-index: 1;
	background: #0a0a0a;
}

.contact p {
	color: #888;
	margin-bottom: 2rem;
}

	.contact p {
		color: #888;
		margin-bottom: 0;
	}

	.lightbox {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0,0,0,0.95);
		z-index: 1000;
		align-items: center;
		justify-content: center;
		cursor: pointer;
	}

	.lightbox.active {
		display: flex;
	}

	.lightbox-content {
		max-width: 90vw;
		max-height: 90vh;
	}

	#lightbox-img {
		max-width: 90vw;
		max-height: 90vh;
		display: none;
	}

	#lightbox-video {
		width: 90vw;
		max-width: 1200px;
		aspect-ratio: 16/9;
		border: none;
		display: none;
	}

	.hero-btns {
	display: flex;
	gap: 1rem;
	justify-content: center;
	margin-top: 2rem;
}

.hero-btns .btn {
	margin-top: 0;
}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const lightbox = document.getElementById('lightbox');
		const lightboxImg = document.getElementById('lightbox-img');
		const lightboxVideo = document.getElementById('lightbox-video');

		document.querySelectorAll('.photo-card').forEach(card => {
			card.addEventListener('click', () => {
				const src = card.querySelector('img').src;
				lightboxImg.src = src;
				lightboxImg.style.display = 'block';
				lightboxVideo.style.display = 'none';
				lightboxVideo.src = '';
				lightbox.classList.add('active');
			});
		});

		document.querySelectorAll('.video-card').forEach(card => {
			card.addEventListener('click', () => {
				const url = card.dataset.url;
				const videoId = url.includes('youtu.be') ? url.split('youtu.be/')[1] : url.split('v=')[1];
				lightboxVideo.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
				lightboxVideo.style.display = 'block';
				lightboxImg.style.display = 'none';
				lightboxImg.src = '';
				lightbox.classList.add('active');
			});
		});

		lightbox.addEventListener('click', () => {
			lightboxVideo.src = '';
			lightbox.classList.remove('active');
		});
	});
</script>